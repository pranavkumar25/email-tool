# ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit the filled-in file.
# ─────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
# We use Supabase only as a hosted Postgres DB (via Prisma) — NOT the Supabase
# JS SDK / Supabase Auth. Grab both URLs from: Supabase Dashboard > Connect >
# ORMs tab > Prisma.
#   DATABASE_URL = pooled connection (Supavisor, port 6543) used by the app.
#   DIRECT_URL   = direct connection (port 5432) used by `prisma db push`/migrations.
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- NextAuth / Auth.js ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-me"
# Base URL of the app. http://localhost:3000 for local dev; your Vercel URL in prod.
AUTH_URL="http://localhost:3000"

# --- Google OAuth client (from GCP Console > Credentials > OAuth client ID) ---
# This is the "Internal" web-app client created under the pickcel.com org.
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="replace-me"

# --- Tracking / ingest ---
# Public base URL used to build open-pixel and click-redirect links that the
# Apps Script bakes into outgoing mail. Same as AUTH_URL in most setups.
TRACKING_BASE_URL="http://localhost:3000"
# Shared secret the Apps Script uses to POST SENT/REPLY events back to the app.
INGEST_SECRET="replace-me"

# --- Token encryption (for refresh tokens at rest) ---
# 32-byte base64 key:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY="replace-me"

# --- Admin access ---
# Comma-separated emails granted in-app admin (the /admin console + "view as"
# any workspace). Admin is derived from this allowlist on Google sign-in — there
# is no password and no DB role. A user must sign in once before they're listed.
ADMIN_EMAILS=""
